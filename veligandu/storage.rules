rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for villa images
    match /villas/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Admin only for all other files
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
