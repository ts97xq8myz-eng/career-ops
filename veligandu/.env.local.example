# ============================================================
# Veligandu Booking Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Firebase (Client SDK) ---
# Get these from: Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:000000000000

# --- Google Analytics / Ads ---
# Get from: Google Ads → Tools → Conversions → Measurement → Tag setup
NEXT_PUBLIC_GTAG_ID=AW-XXXXXXXXXX

# --- Meta Pixel ---
# Get from: Meta Business Suite → Events Manager → Pixels
NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# --- Google Places (for resort photography) ---
# Get from: Google Cloud Console → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key
NEXT_PUBLIC_GOOGLE_PLACES_ID=ChIJxxxxxxxxxxxxxxxx

# --- Resort Contact ---
NEXT_PUBLIC_WHATSAPP_NUMBER=+9609999999
NEXT_PUBLIC_RESORT_EMAIL=reservations@veligandu.com

# --- Flight Booking Engine ---
# URL of your preferred flight booking partner (Skyscanner, Google Flights, etc.)
NEXT_PUBLIC_FLIGHT_ENGINE_URL=https://www.skyscanner.net/transport/flights

# --- Firebase Admin SDK (server-side only — NEVER expose publicly) ---
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_ADMIN_KEY={"type":"service_account","project_id":"..."}

# --- Stripe (payment pre-auth) ---
# Get from: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# --- Email Provider ---
# SendGrid: sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# --- Kafka (optional — leave unset to use mock adapter) ---
# KAFKA_ENABLED=true
# KAFKA_BROKERS=broker1:9092,broker2:9092
# KAFKA_CLIENT_ID=veligandu-booking

# --- Webhook security ---
WEBHOOK_SECRET=your_webhook_secret_here

# --- Booking.com API (optional — for live rate sync) ---
# BOOKING_COM_API_KEY=your_booking_com_api_key
